# URL da Function URL do Lambda (ver saída do `npx ampx sandbox` ou do stack de produção)
VITE_API_URL=https://xxxxxxxxxxxxxxxxxxxxxxxxxx.lambda-url.us-east-1.on.aws

# Opcional: Measurement ID do GA4 (crie uma propriedade em analytics.google.com).
# Sem essa variável, o app funciona normalmente e só não carrega analytics.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
